<%- include('layout-top') %>

<div class="admin-page-header">
  <h1><%= notice ? 'Edit Notice' : 'New Notice' %></h1>
  <p><%= notice ? 'Update notice details' : 'Create a new notice or announcement' %></p>
</div>

<div class="admin-section" style="max-width:700px;">
  <form action="<%= notice ? `/admin/notices/${notice._id}?_method=PUT` : '/admin/notices' %>" method="POST">

    <div class="form-group" style="margin-bottom:18px;">
      <label style="display:block;font-weight:600;margin-bottom:6px;color:var(--navy);">Notice Title <span style="color:#dc2626;">*</span></label>
      <input type="text" name="title" value="<%= notice ? notice.title : '' %>" placeholder="Enter notice title..." required
        style="width:100%;padding:12px 16px;border:2px solid #e5e7eb;border-radius:10px;font-size:.95rem;font-family:'DM Sans',sans-serif;outline:none;box-sizing:border-box;transition:border-color .2s;"
        onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='#e5e7eb'">
    </div>

    <div class="form-group" style="margin-bottom:18px;">
      <label style="display:block;font-weight:600;margin-bottom:6px;color:var(--navy);">Content <span style="color:#dc2626;">*</span></label>
      <textarea name="content" rows="6" placeholder="Enter the full notice content..." required
        style="width:100%;padding:12px 16px;border:2px solid #e5e7eb;border-radius:10px;font-size:.95rem;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;box-sizing:border-box;transition:border-color .2s;"
        onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='#e5e7eb'"><%= notice ? notice.content : '' %></textarea>
    </div>

    <!-- External Link field -->
    <div class="form-group" style="margin-bottom:18px;">
      <label style="display:block;font-weight:600;margin-bottom:6px;color:var(--navy);">
        🔗 External Link
        <span style="font-weight:400;font-size:.76rem;color:var(--gray);margin-left:6px;">(optional — shown as a button on the notice card)</span>
      </label>
      <div style="position:relative;">
        <span style="position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:.9rem;pointer-events:none;">🔗</span>
        <input type="url" name="externalLink"
          value="<%= notice ? (notice.externalLink||'') : '' %>"
          placeholder="https://example.com/circular.pdf  (leave blank if not needed)"
          style="width:100%;padding:12px 16px 12px 38px;border:2px solid #e5e7eb;border-radius:10px;font-size:.88rem;font-family:'DM Sans',sans-serif;outline:none;box-sizing:border-box;transition:border-color .2s;"
          onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='#e5e7eb'"
          id="extLinkInput">
      </div>
      <!-- Live preview -->
      <div id="linkPreview" style="display:none;margin-top:8px;padding:8px 12px;background:rgba(26,58,107,.05);border:1px solid rgba(26,58,107,.15);border-radius:8px;font-size:.78rem;color:var(--blue);display:flex;align-items:center;gap:7px;">
        <span>Preview:</span>
        <a id="linkPreviewA" href="#" target="_blank" style="font-weight:700;color:var(--blue);text-decoration:none;display:inline-flex;align-items:center;gap:4px;">
          🔗 View / Download <span style="font-size:.7rem;">↗</span>
        </a>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;">
      <div class="form-group">
        <label style="display:block;font-weight:600;margin-bottom:6px;color:var(--navy);">Category</label>
        <select name="category" style="width:100%;padding:12px 16px;border:2px solid #e5e7eb;border-radius:10px;font-size:.9rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .2s;"
          onfocus="this.style.borderColor='var(--accent)'" onblur="this.style.borderColor='#e5e7eb'">
          <% ['Academic','Admission','Examination','Event','General'].forEach(cat => { %>
            <option <%= notice && notice.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group" style="display:flex;align-items:center;gap:10px;padding-top:28px;">
        <input type="checkbox" name="isImportant" id="isImportant" value="true"
          <%= notice && notice.isImportant ? 'checked' : '' %>
          style="width:18px;height:18px;cursor:pointer;accent-color:var(--accent);">
        <label for="isImportant" style="font-weight:600;color:var(--navy);cursor:pointer;">Mark as Important ⚠️</label>
      </div>
    </div>

    <div style="display:flex;gap:12px;">
      <button type="submit" class="admin-btn admin-btn-primary"><%= notice ? '✅ Update Notice' : '📋 Publish Notice' %></button>
      <a href="/admin/notices" class="admin-btn admin-btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
const input   = document.getElementById('extLinkInput');
const preview = document.getElementById('linkPreview');
const previewA= document.getElementById('linkPreviewA');

function updatePreview() {
  const val = input.value.trim();
  if (val && (val.startsWith('http://') || val.startsWith('https://'))) {
    preview.style.display = 'flex';
    previewA.href = val;
  } else {
    preview.style.display = 'none';
  }
}
input.addEventListener('input', updatePreview);
updatePreview(); // run on load for edit mode
</script>

<%- include('layout-bottom') %>
