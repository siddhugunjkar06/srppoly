<%- include('layout-top') %>

<div class="admin-page-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:16px;">
  <div>
    <h1>Notices & Announcements</h1>
    <p>Manage notices displayed on the public website</p>
  </div>
  <a href="/admin/notices/new" class="admin-btn admin-btn-primary">+ New Notice</a>
</div>

<div class="admin-section">
  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr><th>#</th><th>Title</th><th>Category</th><th>Important</th><th>Published</th><th>Actions</th></tr>
      </thead>
      <tbody>
        <% if (notices && notices.length > 0) { %>
          <% notices.forEach((n, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td>
                <strong><%= n.title %></strong>
                <div style="font-size:.75rem;color:var(--gray);margin-top:2px;"><%= n.content.substring(0,80) %>...</div>
              </td>
              <td><span class="notice-cat notice-cat-<%= n.category.toLowerCase() %>"><%= n.category %></span></td>
              <td><%= n.isImportant ? '⚠️ Yes' : '—' %></td>
              <td><%= new Date(n.publishedAt).toLocaleDateString('en-IN') %></td>
              <td style="display:flex;gap:6px;flex-wrap:wrap;">
                <a href="/admin/notices/<%= n._id %>/edit" class="admin-btn admin-btn-secondary admin-btn-sm">Edit</a>
                <form action="/admin/notices/<%= n._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete this notice?')">
                  <button type="submit" class="admin-btn admin-btn-danger admin-btn-sm">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="6" style="text-align:center;color:var(--gray);padding:40px;">No notices yet. <a href="/admin/notices/new">Create one →</a></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('layout-bottom') %>
