<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= title %></title>
<link rel="icon" type="image/png" href="/images/logobg.png">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
<style>
* { box-sizing: border-box; }
body { background: var(--navy); display:flex; align-items:center; justify-content:center; min-height:100vh; padding: 24px; }
.signup-box { background:white; border-radius:20px; padding:44px 48px; max-width:480px; width:100%; box-shadow:0 24px 80px rgba(0,0,0,0.4); }
.signup-logo { text-align:center; margin-bottom:28px; }
.signup-logo .logo-icon { width:64px;height:64px;background:linear-gradient(135deg,var(--navy),var(--blue));border-radius:16px;display:inline-flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.6rem;color:var(--accent);font-weight:900;margin-bottom:12px; }
.signup-logo h2 { font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--navy);margin-bottom:4px; }
.signup-logo p  { font-size:.78rem;color:var(--gray);font-family:'Space Mono',monospace; }

.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.form-group { display:flex; flex-direction:column; gap:5px; }
.form-group.full { grid-column: 1 / -1; }
.form-group label { font-size:.8rem; font-weight:700; color:var(--navy); }
.form-group input { color:black;
  padding:11px 14px; border:2px solid #e5e7eb; border-radius:10px;
  font-family:'DM Sans',sans-serif; font-size:.88rem; transition:border-color .2s; outline:none;
}
.form-group input:focus { border-color:var(--accent); }
.form-hint { font-size:.7rem; color:var(--gray); margin-top:2px; }

.divider { height:1px; background:#f1f5f9; margin:20px 0; }

.invite-field { background:#fffbeb; border-radius:12px; padding:14px 16px; border:1px solid #fde68a; }
.invite-field label { color:#92400e; }
.invite-field input { color:black; border-color:#fbbf24; background:white; }
.invite-field input:focus { border-color:#d97706; }
.invite-note { font-size:.72rem; color:#92400e; margin-top:4px; }

.submit-btn { width:100%;padding:14px;background:linear-gradient(135deg,var(--accent),var(--gold));color:var(--navy);font-weight:700;font-size:.95rem;border:none;border-radius:10px;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:20px;transition:all .3s; }
.submit-btn:hover { transform:translateY(-2px);box-shadow:0 8px 24px rgba(212,168,67,.4); }

.login-link { text-align:center;margin-top:20px;font-size:.82rem;color:var(--gray); }
.login-link a { color:var(--navy);font-weight:600;text-decoration:none; }

.flash-error,.flash-success { padding:12px 16px;border-radius:10px;margin-bottom:20px;font-size:.85rem;font-weight:500; }
.flash-error   { background:#fee2e2;color:#991b1b;border:1px solid #fca5a5; }
.flash-success { background:#d1fae5;color:#065f46;border:1px solid #6ee7b7; }

@media(max-width:480px) { .form-grid { grid-template-columns:1fr; } .signup-box { padding:32px 24px; } }
</style>
</head>
<body>
<div class="signup-box">
  <div class="signup-logo">
    <div class="logo-icon"><img src="/images/logo.png" alt="SRPP Logo" style="height:60px;"></div>
    <h2>Create Admin Account</h2>
    <p>SRPP Polytechnic Institute</p>
  </div>

  <% if (error && error.length > 0) { %><div class="flash-error">⚠️ <%= error[0] %></div><% } %>
  <% if (success && success.length > 0) { %><div class="flash-success">✅ <%= success[0] %></div><% } %>

  <form action="/admin/signup" method="POST">
    <div class="form-grid">

      <div class="form-group full">
        <label>Full Name <span style="color:#dc2626">*</span></label>
        <input type="text" name="name" placeholder="e.g. Rajesh Sharma" required autofocus>
      </div>

      <div class="form-group full">
        <label>Gmail Address <span style="color:#dc2626">*</span></label>
        <input type="email" name="email" placeholder="yourname@gmail.com" required>
        <span class="form-hint">Used for account identification only</span>
      </div>

      <div class="form-group">
        <label>Username <span style="color:#dc2626">*</span></label>
        <input type="text" name="username" placeholder="admin_name" required
          pattern="[a-zA-Z0-9_]+" title="Letters, numbers and underscore only">
        <span class="form-hint">Letters, numbers, underscore</span>
      </div>

      <div class="form-group">
        <!-- spacer on desktop -->
      </div>

      <div class="form-group">
        <label>Password <span style="color:#dc2626">*</span></label>
        <input type="password" name="password" placeholder="Min 6 characters" required minlength="6">
      </div>

      <div class="form-group">
        <label>Confirm Password <span style="color:#dc2626">*</span></label>
        <input type="password" name="confirmPassword" placeholder="Repeat password" required>
      </div>

    </div>

    <div class="divider"></div>

    <div class="invite-field">
      <div class="form-group">
        <label>🔑 Invite Code <span style="color:#dc2626">*</span></label>
        <input type="password" name="invite" placeholder="Enter invite code" required>
        <span class="invite-note">Contact the super-admin for the invite code. Set via <code>ADMIN_INVITE_CODE</code> in .env</span>
      </div>
    </div>

    <button type="submit" class="submit-btn">Create Account →</button>
  </form>

  <div class="login-link">
    Already have an account? <a href="/admin/login">Sign In →</a>
    &nbsp;·&nbsp; <a href="/">← Back to Website</a>
  </div>
</div>
</body>
</html>
