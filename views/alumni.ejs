<%- include('partials/head') %>
<%- include('partials/navbar') %>

<%
const DEPT_META = {
  'Electrical Engineering':      { icon:'⚡', color:'#1a3a6b', light:'#dbeafe', text:'#1e40af' },
  'Computer Engineering':        { icon:'💻', color:'#1a5c1a', light:'#dcfce7', text:'#166534' },
  'AI & Machine Learning':       { icon:'🤖', color:'#5c1a5c', light:'#f3e8ff', text:'#7c3aed' },
  'Electronics & Communication': { icon:'📡', color:'#5c3a1a', light:'#ffedd5', text:'#c2410c' },
};
const showYears = activeYear === 'All' ? years : [parseInt(activeYear)];
const showDepts = activeDept === 'All' ? DEPTS : [activeDept];
const totalAlumni = Object.values(grouped).reduce((t, depts) =>
  t + Object.values(depts).reduce((d, arr) => d + arr.length, 0), 0);
%>

<!-- ── HERO ── -->
<section class="al-hero">
  <div class="al-hero-bg"></div>
  <div class="al-hero-dots"></div>
  <div class="section-inner" style="position:relative;z-index:2;">
    <div class="al-hero-inner">
      <div>
        <div class="al-hero-tag">OUR PRIDE · SRPP ALUMNI</div>
        <h1 class="al-hero-title">Where Are They <br><em>Now?</em></h1>
        <p class="al-hero-sub">Meet the graduates of Shri Ramkrishna Paramhans Polytechnic Institute who are making their mark across industries and institutions.</p>
        <div class="al-hero-stats">
          <div class="al-stat">
            <span class="al-stat-n"><%= totalAlumni %></span>
            <span class="al-stat-l">Featured Alumni</span>
          </div>
          <div class="al-stat-div"></div>
          <div class="al-stat">
            <span class="al-stat-n"><%= years.length %></span>
            <span class="al-stat-l">Batches</span>
          </div>
          <div class="al-stat-div"></div>
          <div class="al-stat">
            <span class="al-stat-n"><%= DEPTS.length %></span>
            <span class="al-stat-l">Departments</span>
          </div>
        </div>
      </div>

      <!-- Floating cards preview -->
      <div class="al-hero-cards" aria-hidden="true">
        <% const previewCards = Object.values(grouped).flatMap(d=>Object.values(d).flat()).slice(0,3); %>
        <% previewCards.forEach((a,i) => { %>
          <div class="al-float-card al-float-<%= i+1 %>">
            <div class="al-float-avatar">
              <% if (a.imageUrl) { %>
                <img src="<%= a.imageUrl %>" alt="<%= a.name %>">
              <% } else { %>
                <span><%= a.name.charAt(0) %></span>
              <% } %>
            </div>
            <div class="al-float-info">
              <div class="al-float-name"><%= a.name %></div>
              <div class="al-float-detail">
                <% if (a.statusType==='job' && a.companyName) { %><%= a.companyName %>
                <% } else if (a.statusType==='higher_education' && a.collegeName) { %><%= a.collegeName %>
                <% } else { %><%= a.passOutYear %> Batch<% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<!-- ── FILTER BAR ── -->
<div class="al-filter-bar">
  <div class="section-inner">
    <div class="al-filter-row">
      <span class="al-filter-label">DEPT</span>
      <div class="al-tabs-wrap">
        <% ['All',...DEPTS].forEach(d => {
          const m = DEPT_META[d];
        %>
          <a href="/alumni?dept=<%= encodeURIComponent(d) %>&year=<%= activeYear %>"
             class="al-tab <%= activeDept===d?'al-tab-on':'' %>">
            <%= m ? m.icon+' ' : '🏛️ ' %><%= d==='All'?'All Depts':d.split(' ').slice(0,2).join(' ') %>
          </a>
        <% }) %>
      </div>
    </div>
    <div class="al-filter-row" style="margin-top:8px;">
      <span class="al-filter-label">BATCH</span>
      <div class="al-tabs-wrap">
        <a href="/alumni?dept=<%= encodeURIComponent(activeDept) %>&year=All"
           class="al-stab <%= activeYear==='All'?'al-stab-on':'' %>">All Batches</a>
        <% years.forEach(y => { %>
          <a href="/alumni?dept=<%= encodeURIComponent(activeDept) %>&year=<%= y %>"
             class="al-stab <%= String(activeYear)===String(y)?'al-stab-on':'' %>"><%= y %></a>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- ── CONTENT ── -->
<section style="padding:48px 0 80px;background:#f8fafc;min-height:60vh;">
  <div class="section-inner">

    <% if (years.length === 0 || showYears.every(y => !grouped[y])) { %>
      <div style="text-align:center;padding:80px 20px;">
        <div style="font-size:4rem;margin-bottom:16px;">🎓</div>
        <h3 style="font-family:'Playfair Display',serif;color:var(--navy);margin-bottom:8px;">No Alumni Records Yet</h3>
        <p style="color:var(--gray);">Alumni will appear here once added from the admin panel.</p>
      </div>
    <% } %>

    <% showYears.forEach(year => {
      if (!grouped[year]) return;
      const depts = Object.keys(grouped[year]).filter(d => showDepts.includes(d));
      if (depts.length === 0) return;
    %>

    <!-- Year section -->
    <div class="al-year-section">

      <!-- Year heading -->
      <div class="al-year-head">
        <div class="al-year-num"><%= year %></div>
        <div>
          <h2 class="al-year-title">Batch of <%= year %></h2>
          <p class="al-year-sub">
            <%= depts.reduce((t,d)=>t+grouped[year][d].length,0) %> featured alumni
          </p>
        </div>
        <div class="al-year-line"></div>
      </div>

      <!-- Department sections inside this year -->
      <% depts.forEach(dept => {
        const m = DEPT_META[dept] || {};
        const students = grouped[year][dept];
      %>

      <div class="al-dept-row">

        <!-- Dept label sidebar -->
        <div class="al-dept-label-col">
          <div class="al-dept-icon-pub" style="background:<%= m.color||'#0a1628' %>"><%= m.icon||'📚' %></div>
          <div class="al-dept-name-pub"><%= dept %></div>
          <div class="al-dept-count-pub">Top <%= students.length %></div>
        </div>

        <!-- Cards grid -->
        <div class="al-cards-grid">
          <% students.forEach((a, i) => {
            const rank = i + 1;
          %>
          <div class="al-card fade-in" style="animation-delay:<%= i*0.07 %>s;">

            <!-- Rank badge -->
            <div class="al-card-rank"><%= rank %></div>

            <!-- Photo -->
            <div class="al-card-photo-wrap">
              <% if (a.imageUrl) { %>
                <img src="<%= a.imageUrl %>" alt="<%= a.name %>" class="al-card-photo">
              <% } else { %>
                <div class="al-card-photo al-card-photo-placeholder" style="background:<%= m.color||'var(--navy)' %>;">
                  <span><%= a.name.charAt(0) %></span>
                </div>
              <% } %>
              <!-- Status dot -->
              <div class="al-card-status-dot <%= a.statusType==='job'?'dot-job':a.statusType==='higher_education'?'dot-edu':'dot-other' %>"></div>
            </div>

            <!-- Name & enrollment -->
            <div class="al-card-name"><%= a.name %></div>
            <% if (a.enrollmentNo) { %>
              <div class="al-card-enroll"><%= a.enrollmentNo %></div>
            <% } %>

            <!-- Dept tag -->
            <div class="al-card-dept-tag" style="background:<%= m.light||'#f1f5f9' %>;color:<%= m.text||'#334155' %>;">
              <%= m.icon %> <%= dept.split(' ').slice(0,2).join(' ') %>
            </div>

            <!-- Current status -->
            <div class="al-card-status-box">
              <% if (a.statusType === 'job') { %>
                <div class="al-status-icon">💼</div>
                <div class="al-status-content">
                  <div class="al-status-type">Working at</div>
                  <div class="al-status-val"><%= a.companyName || '—' %></div>
                  <% if (a.jobRole) { %><div class="al-status-sub"><%= a.jobRole %></div><% } %>
                </div>
              <% } else if (a.statusType === 'higher_education') { %>
                <div class="al-status-icon">🎓</div>
                <div class="al-status-content">
                  <div class="al-status-type">Studying at</div>
                  <div class="al-status-val"><%= a.collegeName || '—' %></div>
                  <% if (a.courseName) { %><div class="al-status-sub"><%= a.courseName %></div><% } %>
                </div>
              <% } else { %>
                <div class="al-status-icon">🔹</div>
                <div class="al-status-content">
                  <div class="al-status-val"><%= a.otherStatus || '—' %></div>
                </div>
              <% } %>
            </div>

            <!-- Pass out year badge -->
            <div class="al-card-year-badge">Batch <%= a.passOutYear %></div>

            <!-- Message -->
            <% if (a.message) { %>
              <div class="al-card-message">
                <span class="al-msg-quote">"</span><%= a.message %><span class="al-msg-quote">"</span>
              </div>
            <% } %>

          </div>
          <% }) %>
        </div>

      </div><!-- .al-dept-row -->
      <% }) %>
    </div><!-- .al-year-section -->
    <% }) %>

  </div>
</section>

<!-- ── CTA ── -->
<section style="background:linear-gradient(135deg,var(--navy),var(--blue));padding:56px 0;text-align:center;">
  <div class="section-inner">
    <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.5rem,4vw,2.2rem);color:white;margin-bottom:12px;">Are You an SRPP Alumnus?</h2>
    <p style="color:rgba(255,255,255,.65);margin-bottom:28px;max-width:480px;margin-left:auto;margin-right:auto;">Share your success story with the next generation of students. Connect with us!</p>
    <a href="/#contact" class="al-cta-btn">📩 Get in Touch →</a>
  </div>
</section>

<style>
/* ══ HERO ══ */
.al-hero{position:relative;padding:90px 0 64px;overflow:hidden;background:var(--navy);}
.al-hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0a1628 0%,#1a3a6b 60%,#0d2444 100%);z-index:0;}
.al-hero-dots{position:absolute;inset:0;background-image:radial-gradient(rgba(212,168,67,.15) 1px,transparent 1px);background-size:32px 32px;z-index:1;pointer-events:none;}
.al-hero-inner{display:grid;grid-template-columns:1fr 380px;gap:48px;align-items:center;position:relative;z-index:2;}
.al-hero-tag{display:inline-flex;align-items:center;gap:7px;background:rgba(212,168,67,.12);border:1px solid rgba(212,168,67,.3);border-radius:50px;padding:5px 16px;font-family:'Space Mono',monospace;font-size:.68rem;font-weight:700;color:var(--accent);letter-spacing:.1em;margin-bottom:18px;}
.al-hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.2rem,5vw,3.5rem);font-weight:900;color:white;line-height:1.15;margin-bottom:16px;}
.al-hero-title em{color:var(--accent);font-style:italic;}
.al-hero-sub{color:rgba(255,255,255,.6);font-size:1rem;line-height:1.8;max-width:500px;margin-bottom:28px;}
.al-hero-stats{display:flex;align-items:center;gap:24px;flex-wrap:wrap;}
.al-stat{text-align:center;}
.al-stat-n{display:block;font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;color:var(--accent);line-height:1;}
.al-stat-l{font-size:.7rem;color:rgba(255,255,255,.5);font-family:'Space Mono',monospace;text-transform:uppercase;letter-spacing:.06em;}
.al-stat-div{width:1px;height:40px;background:rgba(255,255,255,.15);}

/* Floating cards */
.al-hero-cards{position:relative;height:300px;}
.al-float-card{position:absolute;background:rgba(255,255,255,.1);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.15);border-radius:16px;padding:12px 16px;display:flex;align-items:center;gap:12px;min-width:200px;box-shadow:0 8px 32px rgba(0,0,0,.3);}
.al-float-1{top:10px;right:0;animation:float1 4s ease-in-out infinite;}
.al-float-2{top:100px;right:50px;animation:float2 5s ease-in-out infinite;}
.al-float-3{top:200px;right:10px;animation:float3 4.5s ease-in-out infinite;}
@keyframes float1{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes float2{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes float3{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
.al-float-avatar{width:42px;height:42px;border-radius:50%;border:2px solid var(--accent);overflow:hidden;background:var(--navy);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.al-float-avatar img{width:100%;height:100%;object-fit:cover;}
.al-float-avatar span{font-size:1.1rem;font-weight:800;color:var(--accent);font-family:'Playfair Display',serif;}
.al-float-name{font-size:.82rem;font-weight:700;color:white;}
.al-float-detail{font-size:.7rem;color:rgba(255,255,255,.6);}

/* ══ FILTERS ══ */
.al-filter-bar{background:white;border-bottom:2px solid #e2e8f0;position:sticky;top:70px;z-index:90;box-shadow:0 3px 14px rgba(10,22,40,.07);padding:14px 0;}
.al-filter-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.al-filter-label{font-family:'Space Mono',monospace;font-size:.65rem;font-weight:700;color:var(--gray);letter-spacing:.08em;white-space:nowrap;min-width:36px;}
.al-tabs-wrap{display:flex;gap:6px;flex-wrap:wrap;}
.al-tab{display:inline-flex;align-items:center;gap:4px;padding:5px 13px;border-radius:50px;border:1px solid #e2e8f0;background:white;font-size:.78rem;font-weight:500;color:var(--gray);text-decoration:none;transition:all .2s;white-space:nowrap;}
.al-tab:hover{background:#f1f5f9;color:var(--navy);}
.al-tab-on{background:var(--navy)!important;color:var(--accent)!important;border-color:var(--navy)!important;font-weight:700!important;}
.al-stab{display:inline-flex;align-items:center;padding:4px 11px;border-radius:50px;border:1px solid #e2e8f0;background:white;font-size:.74rem;font-weight:500;color:var(--gray);text-decoration:none;transition:all .2s;white-space:nowrap;}
.al-stab:hover{background:#f1f5f9;color:var(--navy);}
.al-stab-on{background:var(--blue)!important;color:white!important;border-color:var(--blue)!important;font-weight:700!important;}

/* ══ YEAR SECTION ══ */
.al-year-section{margin-bottom:48px;}
.al-year-head{display:flex;align-items:center;gap:18px;margin-bottom:24px;}
.al-year-num{font-family:'Playfair Display',serif;font-size:3rem;font-weight:900;color:var(--accent);line-height:1;text-shadow:0 4px 24px rgba(212,168,67,.2);flex-shrink:0;}
.al-year-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:800;color:var(--navy);margin-bottom:2px;}
.al-year-sub{font-size:.76rem;color:var(--gray);}
.al-year-line{flex:1;height:2px;background:linear-gradient(90deg,rgba(212,168,67,.4),transparent);}

/* ══ DEPT ROW ══ */
.al-dept-row{display:grid;grid-template-columns:140px 1fr;gap:0;background:white;border-radius:18px;border:1px solid #e2e8f0;overflow:hidden;margin-bottom:16px;box-shadow:0 2px 14px rgba(10,22,40,.05);}
.al-dept-label-col{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 12px;background:linear-gradient(180deg,#fafbfc,#f1f5f9);border-right:2px solid #e2e8f0;text-align:center;gap:6px;}
.al-dept-icon-pub{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.6rem;margin-bottom:4px;}
.al-dept-name-pub{font-size:.72rem;font-weight:700;color:var(--navy);line-height:1.4;text-align:center;}
.al-dept-count-pub{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--gray);font-weight:700;background:#e2e8f0;border-radius:50px;padding:2px 8px;}

/* ══ CARDS GRID ══ */
.al-cards-grid{display:flex;flex-wrap:nowrap;overflow-x:auto;gap:14px;padding:16px;scroll-snap-type:x mandatory;}
.al-cards-grid::-webkit-scrollbar{height:4px;}
.al-cards-grid::-webkit-scrollbar-track{background:#f1f5f9;border-radius:50px;}
.al-cards-grid::-webkit-scrollbar-thumb{background:var(--accent);border-radius:50px;}

/* ══ ALUMNI CARD ══ */
.al-card{flex:0 0 200px;scroll-snap-align:start;background:#f8fafc;border:1px solid #e2e8f0;border-radius:18px;padding:16px 14px;display:flex;flex-direction:column;align-items:center;gap:6px;position:relative;transition:all .3s;cursor:default;}
.al-card:hover{box-shadow:0 12px 32px rgba(10,22,40,.12);border-color:var(--accent);transform:translateY(-4px);}
.al-card-rank{position:absolute;top:10px;left:10px;width:22px;height:22px;background:linear-gradient(135deg,var(--accent),var(--gold));border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Space Mono',monospace;font-size:.6rem;font-weight:900;color:var(--navy);}
.al-card-photo-wrap{position:relative;margin-bottom:4px;}
.al-card-photo{width:72px;height:72px;border-radius:50%;border:3px solid var(--accent);object-fit:cover;box-shadow:0 4px 16px rgba(212,168,67,.25);}
.al-card-photo-placeholder{width:72px;height:72px;border-radius:50%;border:3px solid var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-size:1.8rem;font-weight:900;color:white;}
.al-card-status-dot{position:absolute;bottom:4px;right:4px;width:14px;height:14px;border-radius:50%;border:2px solid white;}
.dot-job{background:#16a34a;}
.dot-edu{background:#2563eb;}
.dot-other{background:#9333ea;}
.al-card-name{font-family:'Playfair Display',serif;font-size:.9rem;font-weight:800;color:var(--navy);text-align:center;line-height:1.3;}
.al-card-enroll{font-family:'Space Mono',monospace;font-size:.6rem;color:var(--gray);font-weight:700;}
.al-card-dept-tag{font-size:.62rem;font-weight:700;border-radius:50px;padding:3px 9px;white-space:nowrap;}
.al-card-status-box{display:flex;align-items:flex-start;gap:7px;background:white;border:1px solid #e2e8f0;border-radius:10px;padding:8px 10px;width:100%;margin-top:4px;}
.al-status-icon{font-size:1rem;flex-shrink:0;margin-top:1px;}
.al-status-type{font-family:'Space Mono',monospace;font-size:.56rem;font-weight:700;color:var(--gray);text-transform:uppercase;margin-bottom:2px;}
.al-status-val{font-size:.76rem;font-weight:700;color:var(--navy);line-height:1.3;}
.al-status-sub{font-size:.68rem;color:var(--gray);margin-top:1px;}
.al-card-year-badge{font-family:'Space Mono',monospace;font-size:.6rem;font-weight:700;color:var(--blue);background:rgba(26,58,107,.07);border:1px solid rgba(26,58,107,.12);border-radius:50px;padding:2px 8px;}
.al-card-message{background:linear-gradient(135deg,rgba(212,168,67,.05),rgba(212,168,67,.1));border-left:2px solid var(--accent);border-radius:0 8px 8px 0;padding:8px 10px;width:100%;font-size:.72rem;color:var(--gray);line-height:1.6;font-style:italic;margin-top:4px;}
.al-msg-quote{font-size:1rem;color:var(--accent);font-family:'Playfair Display',serif;font-weight:900;line-height:0;}

/* ══ CTA ══ */
.al-cta-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:linear-gradient(135deg,var(--accent),var(--gold));color:var(--navy);border-radius:50px;font-size:.95rem;font-weight:800;text-decoration:none;transition:all .25s;box-shadow:0 6px 20px rgba(212,168,67,.3);}
.al-cta-btn:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(212,168,67,.45);}

/* ══ RESPONSIVE ══ */
@media(max-width:900px){
  .al-hero-inner{grid-template-columns:1fr;}
  .al-hero-cards{display:none;}
  .al-dept-row{grid-template-columns:1fr;}
  .al-dept-label-col{flex-direction:row;justify-content:flex-start;padding:12px 18px;border-right:none;border-bottom:2px solid #e2e8f0;}
  .al-dept-icon-pub{width:38px;height:38px;margin-bottom:0;}
}
@media(max-width:500px){
  .al-card{flex:0 0 170px;}
}
</style>

<%- include('partials/footer') %>
