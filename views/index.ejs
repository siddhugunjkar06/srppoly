<!-- ═══════════════════════ NOTICES ═══════════════════════ -->
<section id="notices" style="background:var(--light);">
  <div class="section-inner">
    <div class="notices-header">
      <div>
        <div class="section-label">Latest Updates</div>
        <h2 class="section-title">Notices & Announcements</h2>
      </div>
      <a href="/notices" class="btn-outline" style="color:var(--navy);border-color:var(--navy);">View All Notices →</a>
    </div>
    <div class="notices-grid">
      <% if (notices && notices.length > 0) { %>
        <% notices.slice(0, 6).forEach(notice => { %>
          <div class="notice-card fade-in">
            <div class="notice-meta">
              <span class="notice-cat notice-cat-<%= notice.category.toLowerCase() %>"><%= notice.category %></span>
              <% if (notice.isNew) { %><span class="notice-new">NEW</span><% } %>
              <% if (notice.isImportant) { %><span class="notice-important">⚠️ Important</span><% } %>
            </div>
            <h4 class="notice-title"><%= notice.title %></h4>
            <p class="notice-body"><%= notice.content.substring(0, 120) %><%= notice.content.length > 120 ? '...' : '' %></p>
            <div class="notice-date">📅 <%= new Date(notice.publishedAt).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="notice-card fade-in">
          <div class="notice-meta"><span class="notice-cat notice-cat-admission">Admission</span><span class="notice-new">NEW</span></div>
          <h4 class="notice-title">Admissions Open for 2024-25 Academic Year</h4>
          <p class="notice-body">Applications are now being accepted for all diploma programs for the upcoming academic year. Limited seats available.</p>
          <div class="notice-date">📅 1 Jan 2024</div>
        </div>
        <div class="notice-card fade-in">
          <div class="notice-meta"><span class="notice-cat notice-cat-examination">Examination</span></div>
          <h4 class="notice-title">MSBTE Winter 2023 Results Declared</h4>
          <p class="notice-body">MSBTE has declared the Winter 2023 examination results. Students can check results on the official MSBTE website.</p>
          <div class="notice-date">📅 20 Dec 2023</div>
        </div>
        <div class="notice-card fade-in">
          <div class="notice-meta"><span class="notice-cat notice-cat-event">Event</span><span class="notice-new">NEW</span></div>
          <h4 class="notice-title">Annual Technical Fest — TechVision 2024</h4>
          <p class="notice-body">Register for SRPP's annual technical festival featuring competitions, workshops, and industry guest lectures.</p>
          <div class="notice-date">📅 15 Feb 2024</div>
        </div>
      <% } %>
    </div>
  </div>
</section>

<!-- ═══════════════════════ FACULTY ═══════════════════════ -->
<section id="faculty" style="background:var(--white);">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:52px;">
      <div class="section-label" style="justify-content:center;">Meet the Team</div>
      <h2 class="section-title">Our Expert Faculty</h2>
      <p class="section-sub" style="margin:0 auto;">Experienced educators and industry professionals dedicated to shaping the next generation of engineers.</p>
    </div>

    <% if (faculty && faculty.length > 0) { %>
      <div class="faculty-grid">
        <% faculty.forEach(member => { %>
          <div class="faculty-card fade-in">

            <!-- Photo -->
            <% if (member.imageUrl) { %>
              <img
                src="<%= member.imageUrl %>"
                alt="<%= member.name %>"
                class="faculty-avatar"
                style="object-fit:cover;border:3px solid var(--accent);"
              >
            <% } else { %>
              <div class="faculty-avatar"
                style="background:linear-gradient(135deg,var(--navy),var(--blue));font-size:2rem;display:flex;align-items:center;justify-content:center;">
                <%= member.name.charAt(0).toUpperCase() %>
              </div>
            <% } %>

            <div class="faculty-info">
              <h4><%= member.name %></h4>
              <p class="faculty-dept"><%= member.designation %></p>
              <p class="faculty"><%= member.department %></p>
              <p class="faculty-exp"><%= member.qualification %><%= member.experience ? ' · ' + member.experience : '' %></p>
              <% if (member.specialization) { %>
                <div class="faculty-tags">
                  <% member.specialization.split(',').slice(0,2).forEach(s => { %>
                    <span><%= s.trim() %></span>
                  <% }) %>
                </div>
              <% } %>
              <% if (member.isHOD) { %>
                <span style="display:inline-block;margin-top:8px;padding:3px 10px;background:linear-gradient(135deg,var(--accent),var(--gold));border-radius:50px;font-size:.65rem;font-weight:900;color:var(--navy);font-family:'Space Mono',monospace;">HEAD OF DEPARTMENT</span>
              <% } %>
            </div>

          </div>
        <% }) %>
      </div>

    <% } else { %>
      <!-- Fallback static cards when no faculty in DB yet -->
      <div class="faculty-grid">
        <div class="faculty-card fade-in">
          <div class="faculty-avatar" style="background:linear-gradient(135deg,var(--navy),var(--blue))">👨‍🏫</div>
          <div class="faculty-info">
            <h4>Dr. Ramesh Patil</h4>
            <p class="faculty-dept">Principal & HOD — Electrical</p>
            <p class="faculty-exp">M.Tech, Ph.D · 20+ Years Experience</p>
            <div class="faculty-tags"><span>Power Systems</span><span>PLC</span></div>
          </div>
        </div>
        <div class="faculty-card fade-in">
          <div class="faculty-avatar" style="background:linear-gradient(135deg,#1a5c1a,#0d3b0d)">👩‍💻</div>
          <div class="faculty-info">
            <h4>Prof. Priya Kulkarni</h4>
            <p class="faculty-dept">HOD — Computer Engineering</p>
            <p class="faculty-exp">M.E. Computer Science · 15+ Years</p>
            <div class="faculty-tags"><span>Web Dev</span><span>Java</span></div>
          </div>
        </div>
        <div class="faculty-card fade-in">
          <div class="faculty-avatar" style="background:linear-gradient(135deg,#5c1a5c,#3b0d3b)">👨‍🔬</div>
          <div class="faculty-info">
            <h4>Prof. Anil Deshmukh</h4>
            <p class="faculty-dept">HOD — AI & Machine Learning</p>
            <p class="faculty-exp">M.Tech AI · 12+ Years Experience</p>
            <div class="faculty-tags"><span>Python</span><span>ML</span></div>
          </div>
        </div>
        <div class="faculty-card fade-in">
          <div class="faculty-avatar" style="background:linear-gradient(135deg,#5c3a1a,#3b1f0d)">👩‍🔬</div>
          <div class="faculty-info">
            <h4>Prof. Sunita Gaikwad</h4>
            <p class="faculty-dept">HOD — Electronics & Comm.</p>
            <p class="faculty-exp">M.E. Electronics · 18+ Years</p>
            <div class="faculty-tags"><span>VLSI</span><span>Embedded</span></div>
          </div>
        </div>
      </div>
    <% } %>

  </div>
</section>

<!-- ═══════════════════════ GALLERY ═══════════════════════ -->
<section id="gallery" style="background:var(--light);">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:36px;">
      <div class="section-label" style="justify-content:center;">Campus Life</div>
      <h2 class="section-title">Photo Gallery</h2>
      <p class="section-sub" style="margin:0 auto;">A glimpse into life at SRPP — our labs, events, sports, and more.</p>
    </div>

    <div class="gallery-tabs" id="galleryTabs">
      <button class="tab-btn active" onclick="filterGallery('all',this)">All</button>
      <button class="tab-btn" onclick="filterGallery('campus',this)">Campus</button>
      <button class="tab-btn" onclick="filterGallery('labs',this)">Labs</button>
      <button class="tab-btn" onclick="filterGallery('events',this)">Events</button>
      <button class="tab-btn" onclick="filterGallery('sports',this)">Sports</button>
      <button class="tab-btn" onclick="filterGallery('achievements',this)">Achievements</button>
      <button class="tab-btn" onclick="filterGallery('cultural',this)">Cultural</button>
    </div>

    <% if (gallery && gallery.length > 0) { %>
      <div class="gallery-grid" id="galleryGrid">
        <% gallery.forEach(img => { %>
          <div class="gallery-item fade-in" data-cat="<%= img.category.toLowerCase() %>">
            <div class="gallery-thumb" style="background:#1a2a4a;">
              <img
                src="<%= img.imageUrl %>"
                alt="<%= img.title %>"
                loading="lazy"
                style="width:100%;height:100%;object-fit:cover;display:block;"
                onerror="this.parentElement.innerHTML='<span style=font-size:2rem>🖼️</span>'"
              >
              <div class="gallery-overlay">
                <%= img.title %>
                <% if (img.description) { %>
                  <span style="font-size:.72rem;opacity:.8;display:block;margin-top:3px;"><%= img.description.substring(0,60) %></span>
                <% } %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

    <% } else { %>
      <!-- Fallback static gallery when no images in DB -->
      <div class="gallery-grid">
        <div class="gallery-item fade-in" data-cat="campus"><div class="gallery-thumb"><span>🏛️</span><div class="gallery-overlay">Main Building</div></div></div>
        <div class="gallery-item fade-in" data-cat="labs"><div class="gallery-thumb"><span>💻</span><div class="gallery-overlay">Computer Lab</div></div></div>
        <div class="gallery-item fade-in" data-cat="labs"><div class="gallery-thumb"><span>⚡</span><div class="gallery-overlay">Electrical Lab</div></div></div>
        <div class="gallery-item fade-in" data-cat="events"><div class="gallery-thumb"><span>🎓</span><div class="gallery-overlay">Convocation</div></div></div>
        <div class="gallery-item fade-in" data-cat="sports"><div class="gallery-thumb"><span>🏏</span><div class="gallery-overlay">Sports Day</div></div></div>
        <div class="gallery-item fade-in" data-cat="events"><div class="gallery-thumb"><span>🤖</span><div class="gallery-overlay">TechFest</div></div></div>
      </div>
    <% } %>

  </div>
</section>

<!-- ═══════════════════════ ADMISSION ═══════════════════════ -->
<section id="admission" style="background:var(--navy);">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:52px;">
      <div class="section-label" style="justify-content:center;color:var(--accent);">Admissions 2024–25</div>
      <h2 class="section-title light">Apply for Admission</h2>
      <p class="section-sub light" style="margin:0 auto;">Fill in your details below and our admissions team will contact you within 24 hours.</p>
    </div>
    <div class="admission-form-wrap fade-in">
      <form class="admission-form" id="admissionForm" action="/enquiry" method="POST">
        <div class="form-grid">
          <div class="form-group">
            <label>First Name *</label>
            <input type="text" name="fname" id="fname" placeholder="First name" required>
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" name="lname" id="lname" placeholder="Last name">
          </div>
          <div class="form-group">
            <label>Email *</label>
            <input type="email" name="email" id="email" placeholder="your@email.com" required>
          </div>
          <div class="form-group">
            <label>Phone *</label>
            <input type="tel" name="phone" id="phone" placeholder="+91 XXXXX XXXXX" required>
          </div>
          <div class="form-group">
            <label>Department *</label>
            <select name="dept" id="dept" required>
              <option value="">Select Department</option>
              <option>Electrical Engineering</option>
              <option>Computer Engineering</option>
              <option>AI & Machine Learning</option>
              <option>Electronics & Communication</option>
            </select>
          </div>
          <div class="form-group">
            <label>10th Marks %</label>
            <input type="text" name="marks" id="marks" placeholder="e.g. 75%">
          </div>
          <div class="form-group">
            <label>Category</label>
            <select name="category">
              <option>General</option>
              <option>OBC</option>
              <option>SC</option>
              <option>ST</option>
              <option>NT</option>
              <option>EWS</option>
            </select>
          </div>
