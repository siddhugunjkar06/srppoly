<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- FLASH MESSAGES -->
<% if (success && success.length > 0) { %>
  <div class="flash-success" id="flashMsg">
    <span>✅ <%= success[0] %></span>
    <button onclick="this.parentElement.style.display='none'">✕</button>
  </div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="flash-error" id="flashMsg">
    <span>⚠️ <%= error[0] %></span>
    <button onclick="this.parentElement.style.display='none'">✕</button>
  </div>
<% } %>

<!-- ═══════════════════════ HERO ═══════════════════════ -->
<section class="hero" id="home">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-badge">🏛️ AICTE Approved · Est. 2008</div>
      <h1>Shape Your Future<br>with <em>Technical Excellence</em></h1>
      <p><b>SRPP Polytechnic Institute</b> offers world-class diploma programs in engineering and technology, empowering students from rural Maharashtra to build extraordinary careers.</p>
      <div class="hero-btns">
        <a href="#admission" class="btn-primary">🎓 Apply for Admission</a>
        <a href="#departments" class="btn-outline">Explore Programs →</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><span class="num" data-target="15">0</span><span class="label">Years of Excellence</span></div>
        <div class="hero-stat"><span class="num" data-target="2000">0</span><span class="label">Alumni Network</span></div>
        <div class="hero-stat"><span class="num" data-target="95">0</span><span class="label">% Placement Rate</span></div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="float-badge"><span class="year">A+</span>MSBTE<br>RATED</div>
      <div class="hero-card">
        <div class="hero-card-title"><span>🎓</span> Our Programs</div>
        <ul class="dept-list">
          <li class="dept-item"><div class="dept-icon">⚡</div><div><div class="dept-name">Electrical Engineering</div><div class="dept-seats">60 Seats · 3 Years</div></div></li>
          <li class="dept-item"><div class="dept-icon">💻</div><div><div class="dept-name">Computer Engineering</div><div class="dept-seats">60 Seats · 3 Years</div></div></li>
          <li class="dept-item"><div class="dept-icon">🤖</div><div><div class="dept-name">AI & Machine Learning</div><div class="dept-seats">60 Seats · 3 Years</div></div></li>
          <li class="dept-item"><div class="dept-icon">📡</div><div><div class="dept-name">Electronics & Comm.</div><div class="dept-seats">30 Seats · 3 Years</div></div></li>
        </ul>
        <div class="hero-accred">
          <div class="accred-tag"><strong>DTE</strong>Code: 2631</div>
          <div class="accred-tag"><strong>MSBTE</strong>Code: 51305</div>
          <div class="accred-tag"><strong>AICTE</strong>Approved</div>
        </div>
      </div>
    </div>
  </div>
  <div class="scroll-hint">SCROLL</div>
</section>

<!-- ═══════════════════════ TICKER ═══════════════════════ -->
<div class="ticker">
  <div class="ticker-wrap" id="tickerWrap">
    <% if (notices && notices.length > 0) { %>
      <% notices.forEach(n => { %>
        <div class="ticker-item"><%= n.isImportant ? '🔴' : '📌' %> <%= n.title %></div>
      <% }) %>
    <% } else { %>
      <div class="ticker-item">🎓 Admissions Open for 2024-25 Academic Year</div>
      <div class="ticker-item">📣 MSBTE Examination Results Declared</div>
      <div class="ticker-item">🏆 SRPP Students Win State-Level Technical Competition</div>
      <div class="ticker-item">📚 New AI & Machine Learning Course Launched</div>
      <div class="ticker-item">🤝 Campus Placement Drive — Top Companies Visiting</div>
    <% } %>
    <!-- duplicate for seamless loop -->
    <% if (notices && notices.length > 0) { %>
      <% notices.forEach(n => { %>
        <div class="ticker-item"><%= n.isImportant ? '🔴' : '📌' %> <%= n.title %></div>
      <% }) %>
    <% } else { %>
      <div class="ticker-item">🎓 Admissions Open for 2024-25 Academic Year</div>
      <div class="ticker-item">📣 MSBTE Examination Results Declared</div>
      <div class="ticker-item">🏆 SRPP Students Win State-Level Technical Competition</div>
    <% } %>
  </div>
</div>

<!-- ═══════════════════════ STATS ═══════════════════════ -->
<section class="stats-section">
  <div class="section-inner">
    <div class="stats-grid">
      <div class="stat-box fade-in"><div class="stat-num" data-target="15">0</div><div class="stat-label">Years of Excellence</div></div>
      <div class="stat-box fade-in"><div class="stat-num" data-target="5">0</div><div class="stat-label">Departments</div></div>
