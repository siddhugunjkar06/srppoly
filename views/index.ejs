      <div class="stat-box fade-in"><div class="stat-num" data-target="50">0</div><div class="stat-label">Expert Faculty</div></div>
      <div class="stat-box fade-in"><div class="stat-num" data-target="25">0</div><div class="stat-label">Industry Partners</div></div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ ABOUT ═══════════════════════ -->
