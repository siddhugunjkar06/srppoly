<%- include('partials/head') %>
<%- include('partials/navbar') %>

<!-- ── HERO ── -->
<section class="lmd-hero" style="background:<%= cfg.color %>;">
  <div class="lmd-hero-glow"></div>
  <div class="section-inner">
    <div class="lmd-hero-inner">
      <div>
        <div class="lmd-hero-icon">🔬</div>
        <div class="section-label" style="color:rgba(255,255,255,.5);margin-bottom:10px;">
          Lab Manuals &nbsp;·&nbsp; <%= cfg.name %> &nbsp;·&nbsp; Semester <%= semester %>
        </div>
        <h1 class="lmd-hero-title">Semester <%= semester %> Lab Manuals</h1>
        <p class="lmd-hero-desc">
          Download subject-wise laboratory manuals as per MSBTE guidelines for
          <strong style="color:var(--accent)"><%= cfg.name %></strong> — Semester <%= semester %>.
        </p>
        <div class="lmd-hero-chips">
          <span class="lmd-chip"><%= cfg.icon %> <%= cfg.name %></span>
          <span class="lmd-chip">📅 Semester <%= semester %> · <%= yearLabel %></span>
          <span class="lmd-chip">🔬 <%= manuals.length %> Subject<%= manuals.length!==1?'s':'' %></span>
        </div>
        <div class="lmd-hero-btns">
          <a href="/departments/<%= slug %>#lab-sem-<%= semester %>" class="lmd-btn-back">← Back to Department</a>
          <% if (manuals.filter(m=>m.pdfUrl).length > 0) { %>
            <a href="#subjects" class="lmd-btn-outline">⬇ Download PDFs ↓</a>
          <% } %>
        </div>
      </div>
      <!-- Sem navigator card -->
      <div class="lmd-nav-card">
        <div class="lmd-nav-title">Jump to Semester</div>
        <div class="lmd-nav-grid">
          <% for (let s=1; s<=6; s++) { %>
            <a href="/departments/<%= slug %>/lab-manuals/<%= s %>"
               class="lmd-nav-btn <%= s===semester ? 'lmd-nav-active' : '' %>">
              <span class="lmd-nav-sem">Sem</span>
              <span class="lmd-nav-num"><%= s %></span>
            </a>
          <% } %>
        </div>
        <a href="/departments/<%= slug %>" class="lmd-dept-link">📖 All Resources →</a>
      </div>
    </div>
  </div>
</section>

<!-- ── BREADCRUMB ── -->
<div class="lmd-breadcrumb">
  <div class="section-inner">
    <a href="/">Home</a><span>›</span>
    <a href="/#departments">Departments</a><span>›</span>
    <a href="/departments/<%= slug %>"><%= cfg.name %></a><span>›</span>
    <span>Lab Manuals — Sem <%= semester %></span>
  </div>
</div>

<!-- ── SUBJECTS SECTION ── -->
<section id="subjects" style="background:var(--light);padding:56px 0;">
  <div class="section-inner">

    <% if (manuals.length === 0) { %>
      <!-- Empty state -->
      <div class="lmd-empty">
        <div style="font-size:3.5rem;margin-bottom:16px;">🔬</div>
        <h2>Lab Manuals Coming Soon</h2>
        <p>Lab manuals for Semester <%= semester %> are being prepared. Please check back soon or contact the department office.</p>
        <a href="/departments/<%= slug %>" class="lmd-btn-back" style="display:inline-flex;margin-top:20px;">← Back to Department</a>
      </div>
    <% } else { %>

      <!-- Header row -->
      <div class="lmd-sec-header">
        <div>
          <div class="section-label">Semester <%= semester %> · <%= yearLabel %></div>
          <h2 class="section-title" style="margin-bottom:8px;">Subject Lab Manuals</h2>
          <p style="color:var(--gray);font-size:.9rem;margin:0;">
            <%= manuals.filter(m=>m.pdfUrl).length %> of <%= manuals.length %> PDFs available for download
          </p>
        </div>
        <!-- Download all info -->
        <% if (manuals.filter(m=>m.pdfUrl).length > 1) { %>
          <div class="lmd-dl-all-box">
            <span style="font-size:1.4rem;">📦</span>
            <div>
              <div style="font-size:.82rem;font-weight:700;color:var(--navy);">Download Individually</div>
              <div style="font-size:.72rem;color:var(--gray);">Click each subject's download button below</div>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Subject cards grid -->
      <div class="lmd-subjects-grid">
        <% manuals.forEach((m, idx) => { %>
          <div class="lmd-subject-card fade-in">

            <!-- Card top stripe -->
            <div class="lmd-card-stripe" style="background:<%= cfg.color %>;">
              <span class="lmd-card-num"><%= String(idx+1).padStart(2,'0') %></span>
              <% if (m.subjectCode) { %>
                <span class="lmd-card-code"><%= m.subjectCode %></span>
              <% } %>
              <% if (m.academicYear) { %>
                <span class="lmd-card-year">📅 <%= m.academicYear %></span>
              <% } %>
            </div>

            <!-- Card body -->
            <div class="lmd-card-body">
              <div class="lmd-card-icon">🔬</div>
              <h3 class="lmd-card-title"><%= m.subjectName %></h3>
              <% if (m.description) { %>
                <p class="lmd-card-desc"><%= m.description %></p>
              <% } %>
            </div>

            <!-- Card footer -->
            <div class="lmd-card-footer">
              <% if (m.pdfUrl) { %>
                <a href="/download/lab-manual/<%= m._id %>" class="lmd-dl-btn">
                  <span class="lmd-dl-icon">⬇</span>
                  <span>Download PDF</span>
                </a>
                <span class="lmd-pdf-badge">PDF</span>
              <% } else { %>
                <span class="lmd-coming-soon">Coming Soon</span>
              <% } %>
            </div>

          </div>
        <% }) %>
      </div>

      <!-- Info note -->
      <div class="lmd-info-note">
        <span style="font-size:1.4rem;flex-shrink:0;">ℹ️</span>
        <p>These lab manuals are prepared as per the MSBTE prescribed syllabus for <strong><%= cfg.name %></strong>.
           For the latest updates visit <a href="https://msbte.org.in" target="_blank">msbte.org.in</a> or contact the department.</p>
      </div>

    <% } %>
  </div>
</section>

<!-- ── OTHER SEMESTERS ── -->
<section style="background:white;padding:44px 0;">
  <div class="section-inner">
    <h3 style="font-family:'DM Sans', sans-serif;font-size:1.2rem;color:var(--navy);margin-bottom:20px;text-align:center;">
      Other Semesters — Lab Manuals
    </h3>
    <div class="lmd-other-sems">
      <% for (let s=1; s<=6; s++) {
        const yl = s<=2?'1st Year':s<=4?'2nd Year':'3rd Year';
        const count = labBySem[s] ? labBySem[s] : 0;
      %>
        <a href="/departments/<%= slug %>/lab-manuals/<%= s %>"
           class="lmd-other-sem-card <%= s===semester?'lmd-other-current':'' %>">
          <div class="lmd-osem-num" style="background:<%= s===semester ? cfg.color : 'var(--light)' %>">
            <span style="font-family:'DM Sans', sans-serif;font-size:.6rem;color:<%= s===semester?'rgba(255,255,255,.6)':'var(--gray)' %>">SEM</span>
            <span style="font-family:'DM Sans', sans-serif;font-size:1.5rem;font-weight:900;color:<%= s===semester?'var(--accent)':'var(--navy)' %>"><%= s %></span>
          </div>
          <div>
            <div style="font-size:.82rem;font-weight:700;color:var(--navy);"><%= yl %></div>
            <div style="font-size:.72rem;color:var(--gray);">
              <%= count %> subject<%= count!==1?'s':'' %>
              <%= s===semester ? ' (current)':'' %>
            </div>
          </div>
        </a>
      <% } %>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

<style>
/* ══ HERO ═══════════════════════════════════════════════════════ */
.lmd-hero { padding:90px 0 60px; position:relative; overflow:hidden; }
.lmd-hero-glow { position:absolute; top:-60px; right:-60px; width:400px; height:400px; border-radius:50%; background:radial-gradient(circle,rgba(255,255,255,.07),transparent 70%); pointer-events:none; }
.lmd-hero-inner { display:grid; grid-template-columns:1fr auto; gap:36px; align-items:center; }
.lmd-hero-icon  { font-size:3rem; margin-bottom:12px; }
.lmd-hero-title { font-family:'DM Sans', sans-serif; font-size:2.5rem; font-weight:900; color:white; line-height:1.2; margin-bottom:12px; }
.lmd-hero-desc  { font-size:.95rem; color:rgba(255,255,255,.75); line-height:1.8; max-width:520px; margin-bottom:18px; }
.lmd-hero-chips { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:22px; }
.lmd-chip { background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.2); color:white; font-size:.75rem; font-weight:600; padding:5px 13px; border-radius:50px; }
.lmd-hero-btns { display:flex; gap:10px; flex-wrap:wrap; }
.lmd-btn-back   { display:inline-flex; align-items:center; gap:7px; padding:10px 20px; background:rgba(255,255,255,.12); border:2px solid rgba(255,255,255,.25); color:white; border-radius:50px; font-size:.85rem; font-weight:700; text-decoration:none; transition:all .2s; }
.lmd-btn-back:hover { background:rgba(255,255,255,.2); }
.lmd-btn-outline { display:inline-flex; align-items:center; gap:7px; padding:10px 20px; background:linear-gradient(135deg,var(--accent),var(--gold)); color:var(--navy); border-radius:50px; font-size:.85rem; font-weight:800; text-decoration:none; transition:all .2s; }
.lmd-btn-outline:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(212,168,67,.35); }

/* Nav card */
.lmd-nav-card { background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.15); backdrop-filter:blur(8px); border-radius:18px; padding:20px; min-width:200px; }
.lmd-nav-title { font-family:'DM Sans', sans-serif; font-size:.62rem; font-weight:700; color:rgba(255,255,255,.5); text-transform:uppercase; letter-spacing:.08em; margin-bottom:14px; }
.lmd-nav-grid  { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:14px; }
.lmd-nav-btn   { display:flex; flex-direction:column; align-items:center; padding:8px 4px; border-radius:10px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.1); text-decoration:none; transition:all .2s; }
.lmd-nav-btn:hover { background:rgba(255,255,255,.18); }
.lmd-nav-active { background:rgba(212,168,67,.25)!important; border-color:var(--accent)!important; }
.lmd-nav-sem   { font-family:'DM Sans', sans-serif; font-size:.52rem; color:rgba(255,255,255,.5); text-transform:uppercase; }
.lmd-nav-num   { font-family:'DM Sans', sans-serif; font-size:1.3rem; font-weight:900; color:var(--accent); line-height:1; }
.lmd-dept-link { display:block; text-align:center; color:rgba(255,255,255,.6); font-size:.75rem; font-weight:600; text-decoration:none; }
.lmd-dept-link:hover { color:var(--accent); }

/* ══ BREADCRUMB ═══════════════════════════════════════════════ */
.lmd-breadcrumb { background:white; border-bottom:1px solid #e2e8f0; padding:11px 0; }
.lmd-breadcrumb .section-inner { display:flex; align-items:center; gap:8px; font-size:.8rem; color:var(--gray); flex-wrap:wrap; }
.lmd-breadcrumb a { color:var(--blue); text-decoration:none; }
.lmd-breadcrumb a:hover { color:var(--accent); }
.lmd-breadcrumb span:last-child { color:var(--navy); font-weight:600; }

/* ══ SECTION HEADER ══════════════════════════════════════════ */
.lmd-sec-header { display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:16px; margin-bottom:32px; }
.lmd-dl-all-box { display:flex; align-items:center; gap:12px; background:rgba(212,168,67,.08); border:1px solid rgba(212,168,67,.2); border-radius:12px; padding:12px 18px; }

/* ══ SUBJECT CARDS ═══════════════════════════════════════════ */
.lmd-subjects-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:20px; margin-bottom:28px; }

.lmd-subject-card { background:white; border-radius:16px; border:1px solid #e2e8f0; overflow:hidden; display:flex; flex-direction:column; transition:all .3s; box-shadow:0 2px 10px rgba(10,22,40,.05); }
.lmd-subject-card:hover { border-color:var(--accent); box-shadow:0 8px 28px rgba(10,22,40,.1); transform:translateY(-3px); }

.lmd-card-stripe { display:flex; align-items:center; gap:8px; padding:10px 16px; }
.lmd-card-num    { font-family:'DM Sans', sans-serif; font-size:1.4rem; font-weight:900; color:var(--accent); line-height:1; }
.lmd-card-code   { background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.2); border-radius:6px; padding:2px 8px; font-family:'Space Mono',monospace; font-size:.65rem; color:white; font-weight:700; margin-left:4px; }
.lmd-card-year   { font-size:.65rem; color:rgba(255,255,255,.55); margin-left:auto; font-family:'Space Mono',monospace; }

.lmd-card-body   { padding:16px 18px 12px; flex:1; }
.lmd-card-icon   { font-size:1.8rem; margin-bottom:10px; }
.lmd-card-title  { font-family:'DM Sans', sans-serif; font-size:1rem; font-weight:800; color:var(--navy); line-height:1.35; margin-bottom:6px; }
.lmd-card-desc   { font-size:.8rem; color:var(--gray); line-height:1.6; margin:0; }

.lmd-card-footer { padding:12px 18px 16px; border-top:1px solid #f1f5f9; display:flex; align-items:center; gap:10px; }
.lmd-dl-btn { display:inline-flex; align-items:center; gap:7px; padding:9px 18px; background:linear-gradient(135deg,var(--navy),#1a3a6b); color:white; border-radius:50px; font-size:.82rem; font-weight:700; text-decoration:none; transition:all .25s; flex:1; justify-content:center; }
.lmd-dl-btn:hover { background:linear-gradient(135deg,var(--accent),var(--gold)); color:var(--navy); transform:translateY(-1px); box-shadow:0 4px 14px rgba(212,168,67,.3); }
.lmd-dl-icon { font-size:1rem; }
.lmd-pdf-badge { background:rgba(5,150,105,.1); color:#065f46; border:1px solid rgba(5,150,105,.2); border-radius:6px; padding:3px 8px; font-family:'Space Mono',monospace; font-size:.62rem; font-weight:700; flex-shrink:0; }
.lmd-coming-soon { color:#94a3b8; font-size:.8rem; font-style:italic; }

/* ══ INFO NOTE ═══════════════════════════════════════════════ */
.lmd-info-note { display:flex; gap:14px; align-items:flex-start; background:rgba(212,168,67,.06); border:1px solid rgba(212,168,67,.2); border-radius:12px; padding:16px 20px; }
.lmd-info-note p { font-size:.82rem; color:var(--gray); line-height:1.7; margin:0; }
.lmd-info-note a { color:var(--blue); font-weight:600; }

/* ══ EMPTY ═══════════════════════════════════════════════════ */
.lmd-empty { text-align:center; background:white; border:2px dashed #e2e8f0; border-radius:16px; padding:60px 24px; max-width:480px; margin:0 auto; }
.lmd-empty h2 { font-family:'DM Sans', sans-serif; color:var(--navy); margin-bottom:10px; }
.lmd-empty p  { color:var(--gray); font-size:.9rem; line-height:1.7; }

/* ══ OTHER SEMS ══════════════════════════════════════════════ */
.lmd-other-sems { display:grid; grid-template-columns:repeat(auto-fill,minmax(160px,1fr)); gap:12px; }
.lmd-other-sem-card { display:flex; align-items:center; gap:12px; background:#f8fafc; border:1px solid #e2e8f0; border-radius:12px; padding:14px 16px; text-decoration:none; transition:all .25s; }
.lmd-other-sem-card:hover { border-color:var(--accent); background:white; box-shadow:0 4px 14px rgba(10,22,40,.07); transform:translateY(-1px); }
.lmd-other-current { border-color:var(--accent)!important; background:white!important; box-shadow:0 4px 14px rgba(10,22,40,.07); }
.lmd-osem-num { width:50px; height:52px; border-radius:10px; display:flex; flex-direction:column; align-items:center; justify-content:center; flex-shrink:0; }

/* ══ RESPONSIVE ═════════════════════════════════════════════ */
@media(max-width:900px) { .lmd-hero-inner { grid-template-columns:1fr; } .lmd-nav-card { display:none; } .lmd-hero-title { font-size:1.9rem; } }
@media(max-width:500px) { .lmd-subjects-grid { grid-template-columns:1fr; } }
</style>
